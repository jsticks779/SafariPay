NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/safaripay
JWT_SECRET=your_jwt_secret_key_here
FRONTEND_URL=http://localhost:3000

# Network Configuration
# Options: TESTNET (Polygon Amoy) | MAINNET (Polygon Mainnet)
SAFARI_NETWORK_MODE=TESTNET

# Global Encryption Secret (Used for AES-256)
ENVIRONMENT_SECRET=your_dynamic_environment_secret_here

# Blockchain Providers (Alchemy or Infura)
ALCHEMY_API_KEY=
# INFURA_API_KEY=
# RPC_URL=

# Contract Addresses (Optional: Defaults provided in code)
# USDT_CONTRACT_ADDRESS_TESTNET=
# USDT_CONTRACT_ADDRESS_MAINNET=

# Guardian Key (Internal Backend Signer)
# SAFARI_GUARDIAN_PRIVATE_KEY=0x...

# Messaging Service (Briq/SMS Gateway)
BRIQ_APP_KEY=
BRIQ_WORKSPACE_ID=
BRIQ_SENDER_ID=
BRIQ_BASE_URL=

# Exchange Rates (Forex)
# Get key at: https://www.exchangerate-api.com/
EXCHANGERATE_API_KEY=

# Decentralized Storage (Filecoin via web3.storage)
# Create a token at: https://web3.storage/
W3S_TOKEN=
